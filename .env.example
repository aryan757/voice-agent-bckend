# OpenAI (LLM)
OPENAI_API_KEY=

# Sarvam (STT + TTS)
SARVAM_API_KEY=

# LiveKit (only needed for `dev` / `start` modes, NOT for `console` mode)
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Questions source (optional).
#   Unset      -> reads the local questions.json (console / laptop testing).
#   A URL      -> the agent GETs questions from there each session, so updating
#                 what's served changes the questions with NO redeploy.
#   Shared set:    https://your-host/questions.json
#   Per-candidate: https://your-planner/interviews/{interview_id}
#                  ({interview_id} is filled from room metadata the frontend sends)
QUESTIONS_URL=
